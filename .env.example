PORT=3001
# Local MongoDB (Option A)
# MONGODB_URI=mongodb://127.0.0.1:27017/appointment_app

# MongoDB Atlas (Option B)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/appointment_app?retryWrites=true&w=majority&appName=<app-name>
JWT_SECRET=replace-with-a-long-random-secret

# Gmail email notifications
GMAIL_ADMIN=your.email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback