<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Tutor Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Roboto', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: linear-gradient(135deg, #e92121, #ffffff);
        }

        h1, h2, h3, h4 {
            font-family: 'Merriweather', serif;
        }

        .page-header {
            background-color: white;
            padding: 15px 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        }

        .page-header img {
            height: 50px;
        }

        .dashboard-wrapper {
            display: grid;
            grid-template-columns: 260px 1fr;
            gap: 20px;
            width: min(1200px, 95%);
            margin: 20px auto;
            flex: 1;
        }

        .sidebar {
            background-color: rgba(255, 255, 255, 0.95);
            border-radius: 14px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            padding: 20px;
            height: fit-content;
        }

        .sidebar a {
            display: block;
            text-decoration: none;
            margin-top: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #7d1c1c;
            font-weight: 600;
            background: #f5f5f5;
        }

        .sidebar a.active {
            background: #e92121;
            color: white;
        }

        .panel {
            background-color: rgba(255, 255, 255, 0.95);
            border-radius: 14px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            padding: 22px;
        }

        .badge-booked {
            background: #007bff;
        }

        .badge-cancelled {
            background: #6c757d;
        }

        .badge-completed {
            background: #28a745;
        }

        .badge-noshow {
            background: #dc3545;
        }

        .footer {
            background-color: #e92121;
            color: white;
            text-align: center;
            padding: 15px 0;
            margin-top: auto;
        }

        @media (max-width: 900px) {
            .dashboard-wrapper {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
<header class="page-header">
    <div>
        <h2 style="color: #e92121; margin-bottom: 0;">Tutor Portal</h2>
        <small class="text-muted">Signed in as <%= tutor.name %> (<%= tutor.email %>)</small>
    </div>
    <a href="/home">
        <img src="/assets/images/isu.png" alt="ISU Logo">
    </a>
</header>

<div class="dashboard-wrapper">
    <aside class="sidebar">
        <h4 style="color: #e92121;">Tutor Panel</h4>
        <a class="active" href="/tutorDashboard">My Appointments</a>
        <a href="/logout">Logout</a>
    </aside>

    <main class="panel">
        <h3>My Appointments</h3>
        <% if (!appointments.length) { %>
            <div class="alert alert-light border mt-3">No appointments assigned yet.</div>
        <% } else { %>
            <div class="table-responsive mt-3">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Course</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    <% appointments.forEach(function(appt) { %>
                        <tr>
                            <td><%= appt.student ? appt.student.name : 'N/A' %></td>
                            <td><%= appt.course %></td>
                            <td><%= new Date(appt.start).toLocaleString() %></td>
                            <td><%= new Date(appt.end).toLocaleString() %></td>
                            <td>
                                <span class="badge badge-<%= appt.status %>"><%= appt.status %></span>
                            </td>
                        </tr>
                    <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </main>
</div>

<footer class="footer">
    <p>&copy; 2026 Illinois State University | Appointment System</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
