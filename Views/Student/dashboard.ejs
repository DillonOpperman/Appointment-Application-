<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Dashboard - IT Learning Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@700&family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: linear-gradient(135deg, #e92121, #ffffff);
        }
        h1, h2, h3, h4 { font-family: 'Merriweather', serif; }

        .page-header {
            background-color: white;
            padding: 15px 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        }
        .page-header img { height: 50px; }

        .dashboard-wrapper {
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 20px;
            width: min(1300px, 95%);
            margin: 20px auto;
            flex: 1;
        }

        .sidebar {
            background-color: rgba(255,255,255,0.95);
            border-radius: 14px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            padding: 20px;
            height: fit-content;
        }
        .sidebar a {
            display: block;
            text-decoration: none;
            margin-top: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #7d1c1c;
            font-weight: 600;
            background: #f5f5f5;
        }
        .sidebar a.active { background: #e92121; color: white; }
        .sidebar a:hover:not(.active) { background: #ffe0e0; }

        .panel {
            background-color: rgba(255,255,255,0.95);
            border-radius: 14px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            padding: 24px;
            margin-bottom: 20px;
        }

        .panel h3 {
            color: #7d1c1c;
            border-bottom: 2px solid #e92121;
            padding-bottom: 10px;
            margin-bottom: 16px;
        }

        .badge-booked    { background-color: #0d6efd; color: white; }
        .badge-cancelled { background-color: #6c757d; color: white; }
        .badge-completed { background-color: #198754; color: white; }
        .badge-noshow    { background-color: #dc3545; color: white; }

        .btn-red {
            background-color: #e92121;
            border-color: #e92121;
            color: white;
            font-weight: 600;
        }
        .btn-red:hover { background-color: #8c1f1f; border-color: #8c1f1f; color: white; }

        .footer {
            background-color: #e92121;
            color: white;
            text-align: center;
            padding: 15px 0;
            margin-top: auto;
        }

        @media (max-width: 900px) {
            .dashboard-wrapper { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

<header class="page-header">
    <div>
        <h2 style="color:#e92121; margin-bottom:0;">Student Portal</h2>
        <small class="text-muted">Signed in as <%= student.name %> (<%= student.email %>)</small>
    </div>
    <a href="/home"><img src="/assets/images/isu.png" alt="ISU Logo"></a>
</header>

<div class="dashboard-wrapper">
    <aside class="sidebar">
        <h4 style="color:#e92121;">Student Panel</h4>
        <a class="active" href="/studentDashboard">My Appointments</a>
        <a href="/home">View Available Slots</a>
        <a href="/logout">Logout</a>
    </aside>

    <div>
        <!-- Notice -->
        <% if (notice) { %>
            <div class="alert alert-<%= noticeType === 'success' ? 'success' : noticeType === 'warning' ? 'warning' : 'danger' %> alert-dismissible fade show" role="alert">
                <%= notice %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- My Appointments -->
        <div class="panel">
            <h3>My Appointments</h3>
            <% if (!appointments.length) { %>
                <div class="alert alert-light border">You have no appointments yet.</div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Tutor</th>
                                <th>Course</th>
                                <th>Start</th>
                                <th>End</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% appointments.forEach(function(appt) { %>
                                <tr>
                                    <td><%= appt.tutor ? appt.tutor.name : 'N/A' %></td>
                                    <td><%= appt.course %></td>
                                    <td><%= new Date(appt.start).toLocaleString() %></td>
                                    <td><%= new Date(appt.end).toLocaleString() %></td>
                                    <td>
                                        <span class="badge badge-<%= appt.status %>"><%= appt.status %></span>
                                    </td>
                                    <td>
                                        <% if (appt.status === 'booked') { %>
                                            <form action="/student/cancelAppointment/<%= appt._id %>" method="POST">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Are you sure you want to cancel this appointment?')">
                                                    Cancel
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <span class="text-muted" style="font-size:0.85rem;">—</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

        <!-- Book a New Appointment -->
        <div class="panel">
            <h3>Book a New Appointment</h3>
            <% if (!availableSlots.length) { %>
                <div class="alert alert-light border">No upcoming slots available right now.</div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Tutor</th>
                                <th>Course</th>
                                <th>Start</th>
                                <th>End</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% availableSlots.forEach(function(slot) { %>
                                <tr>
                                    <td>
                                        <strong><%= slot.tutorName %></strong><br>
                                        <small class="text-muted"><%= slot.tutorEmail %></small>
                                    </td>
                                    <td><%= slot.course %></td>
                                    <td><%= new Date(slot.start).toLocaleString() %></td>
                                    <td><%= new Date(slot.end).toLocaleString() %></td>
                                    <td>
                                        <form action="/student/bookAppointment" method="POST">
                                            <input type="hidden" name="tutorId" value="<%= slot.tutorId %>">
                                            <input type="hidden" name="course" value="<%= slot.course %>">
                                            <input type="hidden" name="start" value="<%= slot.startIso %>">
                                            <input type="hidden" name="end" value="<%= slot.endIso %>">
                                            <button type="submit" class="btn btn-sm btn-red">Book</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<footer class="footer">
    <p>&copy; 2026 Illinois State University | Appointment System</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>